---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

// Get all entries from a collection.
// Requires the name of the collection as an argument.
const allBlogPosts = await getCollection("blog");
const sortedPosts = allBlogPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Musings | YJX">
  <section class="max-w-3xl">
    <div class="mb-8 flex items-center gap-4">
      <h1 class="mt-0 mb-0">Musings</h1>
      <div class="bg-nord-panel h-px flex-grow"></div>
    </div>
    <ul class="tech-marker-list space-y-6">
      {
        sortedPosts.map((post) => (
          <li class="group">
            <a href={`/blog/${post.id}/`} class="block no-underline">
              <h2 class="text-nord-text group-hover:text-nord-purple mb-1 font-mono text-xl transition-colors">
                {post.data.title}
              </h2>
              <div class="text-nord-text/50 mb-2 flex flex-col gap-1 font-mono text-sm">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toISOString().split("T")[0]}
                </time>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="text-nord-blue before:content-['#']">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              {post.data.description && (
                <p class="text-nord-text/70">{post.data.description}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
