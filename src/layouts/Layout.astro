---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title = "YJX | Portfolio & Musings" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <!-- Background and core text properties are applied via @layer base in global.css -->
  <body>
    <!-- Top-level wrapper to restrict max width for reading & viewing ease -->
    <div
      class="bg-nord-bg shadow-nord-bg/50 border-nord-panel/20 mx-auto flex min-h-screen max-w-4xl flex-col border-x px-8 shadow-2xl sm:px-12"
    >
      <Header />
      <main class="flex-grow py-12">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
