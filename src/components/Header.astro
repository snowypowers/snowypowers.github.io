---
const navItems = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects" },
  { label: "Musings", href: "/blog" },
  { label: "About", href: "/about" },
];
---

<header
  class="border-nord-panel/40 flex flex-col gap-4 border-b py-6 md:flex-row md:items-center md:justify-between"
>
  <div>
    <a
      href="/"
      class="text-nord-text hover:text-nord-purple flex items-center gap-2 font-mono text-xl font-bold no-underline"
    >
      <span class="text-nord-blue">[</span>YJX<span class="text-nord-blue"
        >]</span
      >
    </a>
  </div>

  <nav class="w-full md:w-auto">
    <ul class="flex flex-wrap gap-4 font-mono text-sm sm:gap-6">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-nord-text/80 hover:text-nord-purple focus:ring-nord-blue focus:ring-offset-nord-bg rounded-sm no-underline transition-colors focus:ring-2 focus:ring-offset-4 focus:outline-none"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
