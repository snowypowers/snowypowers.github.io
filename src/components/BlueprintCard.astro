---
interface Props {
  class?: string;
  as?: any;
  [key: string]: any;
}

const { as: Element = "div", class: className, ...rest } = Astro.props;
---

<Element
  class:list={[
    "blueprint-card group relative block transition-colors",
    className,
  ]}
  {...rest}
>
  <div
    class="blueprint-bracket-tl group-hover:border-nord-purple transition-colors"
  >
  </div>
  <div
    class="blueprint-bracket-tr group-hover:border-nord-purple transition-colors"
  >
  </div>
  <div
    class="blueprint-bracket-bl group-hover:border-nord-purple transition-colors"
  >
  </div>
  <div
    class="blueprint-bracket-br group-hover:border-nord-purple transition-colors"
  >
  </div>

  <slot />
</Element>
